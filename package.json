{
  "name": "psychological-support",
  "version": "1.2.1",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=\"$NODE_OPTIONS --disable-warning=DEP0205\" next dev",
    "build": "NODE_OPTIONS=\"$NODE_OPTIONS --disable-warning=DEP0205\" next build",
    "start": "NODE_OPTIONS=\"$NODE_OPTIONS --disable-warning=DEP0205\" next start",
    "postinstall": "node scripts/install-playwright-browsers.mjs",
    "lint": "eslint",
    "test": "NODE_OPTIONS=\"$NODE_OPTIONS --disable-warning=DEP0205\" vitest run",
    "test:watch": "NODE_OPTIONS=\"$NODE_OPTIONS --disable-warning=DEP0205\" vitest",
    "test:e2e": "NODE_OPTIONS=\"$NODE_OPTIONS --disable-warning=DEP0205\" playwright test",
    "test:all": "npm run test && npm run build && npm run test:e2e",
    "playwright:install": "npx playwright install chromium"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.58.0",
    "lucide-react": "^0.544.0",
    "next": "^15.5.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-player": "^3.3.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  }
}
